{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PiLauncher",
  "version": "0.1.43",
  "identifier": "com.mrshell.PiLauncher",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm exec vite --host --port 5173 --strictPort",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PiLauncher",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "appimage",
      "dmg",
      "app"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBRERDMERCRERCNEJGQzkKUldUSnY3VGQyOERkT3NtVHlWRXdFbVlZUGdIMG1XVk1OUS83Q0FUaWRVT0QxSnBPSVR1NG14Z0cK",
      "endpoints": [
        "https://pil.nav4ai.net/api/updater?version={{current_version}}&target={{target}}&arch={{arch}}"
      ]
    }
  }
}